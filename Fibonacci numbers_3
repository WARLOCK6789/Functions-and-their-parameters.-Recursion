#include <iostream>
#include <Windows.h>

int Fibonacci(int value)
{
    if (value == 1) return 0;
    if (value == 2) return 1;
    return Fibonacci(value - 1) + Fibonacci(value - 2);
}

int main()
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int a;
    std::cout << "Введите число: ";
    std::cin >> a;

    std::cout << "Числа Фибоначчи: ";
    for (int i = 1; i <= a; i++)
    {
        std::cout << Fibonacci(i) << " ";
    }

    return EXIT_SUCCESS;
}
