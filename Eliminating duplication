#include <iostream>
#include <Windows.h>

int Function(int power, int value)
{
    int result = 1;
    for (int i = 0; i < power; i++)
    {
        result *= value;
    }
    return result;
}

int main(int argc, char** argv)
{
    SetConsoleCP(1251);
    SetConsoleOutputCP(1251);

    int value = 5, power = 2;
    int result = Function(value, power);
    std::cout << value << " в степени " << power << " = " << result << std::endl;

    value = 3;
    power = 3;
    result = Function(value, power);
    std::cout << value << " в степени " << power << " = " << result << std::endl;

    value = 4;
    power = 4;
    result = Function(value, power);
    std::cout << value << " в степени " << power << " = " << result << std::endl;

    return EXIT_SUCCESS;
}
